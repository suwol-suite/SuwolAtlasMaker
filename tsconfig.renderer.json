{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"]
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/shared/i18n/**/*.ts",
    "src/shared/i18n/**/*.json",
    "src/shared/gui-layout.ts",
    "src/shared/gui-types.ts",
    "src/shared/gui-utils.ts",
    "src/shared/batch-set.ts",
    "src/shared/packing.ts",
    "src/shared/sizeMode.ts",
    "src/shared/project.ts"
  ]
}
